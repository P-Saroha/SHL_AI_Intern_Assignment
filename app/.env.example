APP_NAME="SHL Assessment Recommender"
APP_ENV="local"
CATALOG_URL="https://tcp-us-prod-rnd.shl.com/voiceRater/shl-ai-hiring/shl_product_catalog.json"
CATALOG_PATH="app/data/shl_product_catalog.json"
FAISS_INDEX_PATH="app/data/shl_catalog.faiss"
METADATA_PATH="app/data/shl_catalog_metadata.json"
MODEL_CACHE_DIR="app/data/model_cache"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=512
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
MAX_RECOMMENDATIONS=10
